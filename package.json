{
	"name": "open-peeps-api",
	"version": "1.0.0",
	"description": "Cloudflare Worker that generates customizable Open Peeps SVG avatars on-the-fly with full color support via compact protobuf URL tokens",
	"author": "Will Holt",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/willwhiteneck/open-peeps-api"
	},
	"keywords": [
		"open-peeps",
		"avatar",
		"svg",
		"cloudflare-workers",
		"protobuf",
		"illustration",
		"profile-picture",
		"serverless"
	],
	"scripts": {
		"build": "wrangler build",
		"check": "tsc && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest run",
		"lint": "biome check --fix",
		"lint:ci": "biome ci --no-errors-on-unmatched",
		"format": "biome format --write",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,json,jsonc}": "biome ci --no-errors-on-unmatched"
	},
	"dependencies": {
		"@bufbuild/protobuf": "^2.11.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@cloudflare/vitest-pool-workers": "^0.14.1",
		"@cloudflare/workers-types": "^4.20260404.1",
		"@types/node": "24.10.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "5.9.3",
		"vitest": "^4.1.2",
		"wrangler": "4.80.0"
	}
}
